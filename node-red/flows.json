        "name": "OpenWeatherMap",
        "method": "GET",
        "ret": "obj",
        "url": "https://api.openweathermap.org/data/2.5/weather?q=Mogi das Cruzes,BR&appid=SUA_API_KEY_OPENWEATHERMAP&units=metric&lang=pt_br",
        "x": 660, "y": 800,
