    {
        "id": "format-weather",
        "type": "function",
        "z": "7a09ed4d7de03582",
        "name": "Formata Clima",
        "func": "if (!msg.payload.main) {\n  node.warn(\"Erro na API: \" + msg.payload.message);\n  return null;\n}\n\nvar clima = {\n  temp_ext: msg.payload.main.temp,\n  umidade_ext: msg.payload.main.humidity,\n  descricao: msg.payload.weather[0].description\n};\n\nmsg.payload = clima.temp_ext;\nvar msg2 = { payload: clima.umidade_ext };\nvar msg3 = { payload: clima.descricao };\n\nreturn [msg, msg2, msg3];",
        "outputs": 3,
        "x": 860, "y": 800,
        "wires": [["gauge-temp-ext"], ["gauge-umid-ext"], ["text-descricao"]]
    },
