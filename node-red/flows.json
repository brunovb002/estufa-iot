    {
        "id": "alert-temp",
        "type": "function",
        "z": "7a09ed4d7de03582",
        "name": "Alerta Temperatura",
        "func": "var temp = parseFloat(msg.payload);\nif (temp > 35) {\n    msg.payload = true;\n} else {\n    msg.payload = false;\n}\nreturn msg;",
        "outputs": 1,
        "x": 750, "y": 100,
        "wires": [["led-temp"]]
    },
    {
        "id": "alert-umid",
        "type": "function",
        "z": "7a09ed4d7de03582",
        "name": "Alerta Umidade",
        "func": "var umid = parseFloat(msg.payload);\nif (umid < 30) {\n    msg.payload = true;\n} else {\n    msg.payload = false;\n}\nreturn msg;",
        "outputs": 1,
        "x": 790, "y": 180,
        "wires": [["led-umid"]]
    },
