    {
        "id": "format-table",
        "type": "function",
        "z": "7a09ed4d7de03582",
        "name": "Formata Tabela",
        "func": "msg.payload = msg.payload.map(row => {\n    var d = new Date(row.timestamp);\n    var data = d.toLocaleDateString('pt-BR');\n    var hora = d.toLocaleTimeString('pt-BR');\n    return {\n        Timestamp: data + ' ' + hora,\n        Temperatura: row.temperatura + '°C',\n        Umidade: row.umidade + '%',\n        Luminosidade: row.luminosidade + '%'\n    };\n});\nreturn msg;",
        "outputs": 1,
        "x": 900, "y": 1040,
        "wires": [["ui-table"]]
    },
    {
        "id": "ui-table",
        "type": "ui_table",
        "z": "7a09ed4d7de03582",
        "group": "dashboard-group",
        "name": "Últimas Leituras",
        "order": 10, "width": 12, "height": "8",
        "columns": [], "outputs": 0, "cts": false,
