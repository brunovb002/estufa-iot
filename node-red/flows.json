    {
        "id": "mysql-insert",
        "type": "function",
        "z": "7a09ed4d7de03582",
        "name": "Formata SQL",
        "func": "var topic = msg.topic;\nvar value = parseFloat(msg.payload);\n\nif (!context.dados) {\n    context.dados = { temperatura: null, umidade: null, luminosidade: null };\n}\n\nif (topic === \"estufa/temperatura\") context.dados.temperatura = value;\nif (topic === \"estufa/umidade\") context.dados.umidade = value;\nif (topic === \"estufa/luminosidade\") context.dados.luminosidade = value;\n\nif (context.dados.temperatura !== null && \n    context.dados.umidade !== null && \n    context.dados.luminosidade !== null) {\n    \n    msg.topic = \"INSERT INTO leituras (temperatura, umidade, luminosidade) VALUES (\" +\n        context.dados.temperatura + \", \" +\n        context.dados.umidade + \", \" +\n        context.dados.luminosidade + \")\";\n    \n    context.dados = { temperatura: null, umidade: null, luminosidade: null };\n    return msg;\n}\n\nreturn null;",
        "outputs": 1,
        "x": 760, "y": 440,
        "wires": [["mysql-node"]]
    },
